{
  "name": "Staff",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string"
    },
    "photo": {
      "type": "string",
      "format": "uri"
    },
    "full_name": {
      "type": "string"
    },
    "mobile": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "address": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "Super Admin",
        "Admin",
        "Manager",
        "Accountant",
        "Volunteer Coordinator",
        "Event Coordinator",
        "Staff"
      ]
    },
    "joining_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Suspended",
        "Inactive"
      ],
      "default": "Active"
    },
    "department": {
      "type": "string"
    },
    "salary": {
      "type": "number"
    }
  },
  "required": [
    "full_name",
    "role",
    "status"
  ]
}